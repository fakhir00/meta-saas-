{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["business_intent", "saas_type", "core_features", "user_personas"],
  "properties": {
    "business_intent": {
      "type": "object",
      "required": ["value"],
      "properties": {
        "value": { "type": "string" }
      }
    },
    "saas_type": { "type": "string" },
    "core_features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority"],
        "properties": {
          "name": { "type": "string" },
          "priority": { "type": "string" }
        }
      }
    },
    "user_personas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    }
  }
}
