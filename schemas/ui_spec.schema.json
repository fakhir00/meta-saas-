{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "route"],
        "properties": {
          "name": { "type": "string" },
          "route": { "type": "string" }
        }
      }
    }
  }
}
