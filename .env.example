GEMINI_API_KEY=your_gemini_key
STRIPE_SECRET_KEY=your_stripe_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
FALLBACK_MODEL=gemini  # options: gemini | mock

PROVIDER=gemini
GEMINI_API=your_key_here
GEMINI_MAX_TOKENS_CAP=4000
